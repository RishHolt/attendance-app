{
  "name": "attendance-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "concurrently --kill-others \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && npm run electron:compile && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "electron:start": "cross-env NODE_ENV=production electron ."
  },
  "build": {
    "appId": "com.sdo.attendance-system",
    "productName": "SDO Attendance System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/main.js",
      "electron/preload.js"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "standalone/node_modules"
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/public"
      },
      {
        "from": ".env.local",
        "to": "standalone/.env.local"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/speed-insights": "^2.0.0",
    "@xmldom/xmldom": "^0.8.11",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "jose": "^6.1.3",
    "lucide": "^0.575.0",
    "lucide-react": "^0.575.0",
    "motion": "^12.38.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sweetalert2": "^11.26.21",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
